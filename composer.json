{
    "name": "codraw/security",
    "description": "Security related class compatible with symfony/security* component",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "symfony",
        "security"
    ],
    "authors": [
        {
            "name": "Martin Poirier Theoret",
            "email": "mpoiriert@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "firebase/php-jwt": "^6.1",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/http-foundation": "^6.4.0",
        "symfony/http-kernel": "^6.4.0",
        "symfony/security-http": "^6.4.0",
        "symfony/security-core": "^6.4.0",
        "symfony/translation-contracts": "^2.5 || ^3.0"
    },
    "require-dev": {
        "codraw/core": "^0.39",
        "codraw/dependency-injection": "^0.39",
        "codraw/framework-extra-bundle": "^0.39",
        "codraw/messenger": "^0.39",
        "codraw/tester": "^0.39",
        "phpunit/phpunit": "^11.3 || ^12.0",
        "symfony/console": "^6.4.0",
        "symfony/messenger": "^6.4.0"
    },
    "suggest": {
        "codraw/framework-extra-bundle": "To integrate in Symfony",
        "codraw/messenger": "To use the MessageAuthenticator (auto connect from a message link)",
        "symfony/console": "To use the SystemConsoleAuthenticatorListener",
        "symfony/messenger": "To use the SystemMessengerAuthenticatorListener",
        "symfony/security-bundle": "To use the authenticator factories via the DI integration"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\Security\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/security": "self.version"
    }
}
